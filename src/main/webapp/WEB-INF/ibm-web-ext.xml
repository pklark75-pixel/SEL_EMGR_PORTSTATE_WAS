<?xml version="1.0" encoding="UTF-8"?>
<web-ext
    xmlns="http://websphere.ibm.com/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://websphere.ibm.com/xml/ns/javaee
        http://websphere.ibm.com/xml/ns/javaee/ibm-web-ext_1_1.xsd"
    version="1.1">

    <!--
        클래스로더 위임(parentLast) 설정 위치:
          - WLP     : server.xml > <webApplication> > <classloader delegation="parentLast"/>
          - WAS Traditional : 관리 콘솔 > 애플리케이션 > 클래스 로더 > 위임 = parentLast
    -->

    <enable-reloading value="false"/>
    <reload-interval value="0"/>
    <enable-directory-browsing value="false"/>
    <enable-file-serving value="false"/>
    <enable-serving-servlets-by-class-name value="false"/>

</web-ext>
