<?xml version="1.0" encoding="UTF-8"?>
<!--
    WebSphere Liberty Profile (WLP) / Open Liberty server.xml
    ─────────────────────────────────────────────────────────
    로컬 테스트: mvn liberty:run  (liberty-maven-plugin이 자동 기동)
    운영 배포  : ${wlp.install.dir}/usr/servers/<serverName>/server.xml 에 복사
-->
<server description="PFS Portfolio Statement WLP Server">

    <featureManager>
        <feature>servlet-6.0</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="9080"
                  httpsPort="9443"/>

    <!--
        liberty-maven-plugin 사용 시:
          WAR는 {server.config.dir}/apps/ 에 자동 배포됨
        운영 수동 배포 시:
          WAR를 apps/ 폴더에 복사 후 서버 재시작
    -->
    <webApplication id="portstate-was"
                    location="portstate-was-1.0.0-SNAPSHOT.war"
                    contextRoot="/pfs">
        <!--
            ibm-web-ext.xml에 classloader delegation=parentLast 선언되어 있으나
            server.xml에서도 명시적으로 지정 (이중 보장)
        -->
        <classloader delegation="parentLast"/>
    </webApplication>

</server>
